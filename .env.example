# CodeCraft Configuration
# Copy this to .env and fill in your values

# LLM Provider Settings
CODECRAFT_LLM_PROVIDER=openai
CODECRAFT_LLM_MODEL=gpt-4o
CODECRAFT_LLM_OPENAI_API_KEY=
CODECRAFT_LLM_OPENROUTER_API_KEY=
CODECRAFT_LLM_GROQ_API_KEY=
CODECRAFT_LLM_GEMINI_API_KEY=
CODECRAFT_LLM_OLLAMA_HOST=http://localhost:11434

# Deployment Settings
CODECRAFT_DEPLOY_VPS_HOST=
CODECRAFT_DEPLOY_VPS_USER=root
CODECRAFT_DEPLOY_VPS_SSH_KEY=
CODECRAFT_DEPLOY_DOMAIN=gincso.tech
CODECRAFT_DEPLOY_GITHUB_TOKEN=
CODECRAFT_DEPLOY_GITHUB_USER=
CODECRAFT_DEPLOY_CLOUDFLARE_TUNNEL_TOKEN=
CODECRAFT_DEPLOY_CLOUDFLARE_ZONE_ID=
